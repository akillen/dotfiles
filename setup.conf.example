# Copy this file to setup.conf and customize your values.
# setup.sh automatically loads ./setup.conf by default.

# Identity used by scripts/setup-git.sh and scripts/setup-ssh.sh
GIT_NAME="Your Name"
GIT_EMAIL="you@example.com"

# Behavior flags (0 or 1)
ASSUME_YES=0
NO_SOURCE=0
NO_RESTART=0
DOCK_RUNNING_ONLY=0
SKIP_NODE_SETUP=0
SKIP_XCODE=0
SKIP_SIMULATOR=0
SKIP_BROWSER_DEFAULT=0

# Node.js setup preferences (nvm)
NODE_VERSION="node"
NPM_VERSION="latest"
NPM_GLOBAL_PACKAGES="expo eas-cli detox-cli"

# Browser default-handler retry tuning (used when duti hits lock error -54)
BROWSER_RETRY_ATTEMPTS=4
BROWSER_RETRY_DELAY_SECONDS=1

# Optional Google Drive account hint (email only).
# Google Drive uses OAuth login in the app, so password/token preconfiguration
# is not supported by this setup script.
GOOGLE_DRIVE_ACCOUNT_EMAIL=""
